{
  "name": "@agro/database",
  "version": "0.1.0",
  "private": true,
  "description": "Prisma schema and database access foundation",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "lint": "prettier --check . --ignore-path ../../.prettierignore",
    "typecheck": "tsc --noEmit",
    "test": "node ../../tooling/scripts/noop.mjs test @agro/database",
    "db:generate": "prisma generate --schema ./prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema ./prisma/schema.prisma",
    "db:seed": "node --import tsx ./prisma/seed.ts",
    "db:studio": "prisma studio --schema ./prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^7.6.0"
  },
  "devDependencies": {
    "prisma": "^7.6.0",
    "tsx": "^4.20.6"
  }
}
