{
  "name": "@agro/eslint-config",
  "version": "0.1.0",
  "private": true,
  "description": "Shared ESLint configuration package",
  "main": "./base.mjs",
  "exports": {
    ".": "./base.mjs"
  },
  "scripts": {
    "build": "node ../../tooling/scripts/noop.mjs build @agro/eslint-config",
    "lint": "prettier --check . --ignore-path ../../.prettierignore",
    "typecheck": "node ../../tooling/scripts/noop.mjs typecheck @agro/eslint-config",
    "test": "node ../../tooling/scripts/noop.mjs test @agro/eslint-config"
  }
}
